#include <iostream>
using namespace std;
int main()
{
    int num, temp, reverse = 0, remainder;
    cout << "Enter a number: ";
    cin >> num;
    temp = num;
    while (temp > 0)
    {
        remainder = temp % 10;
        reverse = reverse * 10 + remainder;
        temp /= 10;
    }
    if (num == reverse)
        cout << num << " is a Palindrome.";
    else
        cout << num << " is not a Palindrome.";
    return 0;
}
